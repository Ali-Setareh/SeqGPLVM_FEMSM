#!/usr/bin/env bash
set -euo pipefail

# Move to project root (this script lives in slurm/)
cd "$(dirname "$0")/.."

mkdir -p logs

# How many tasks?
COUNT=$(python sweep_simulations.py --count)
echo "Total tasks: $COUNT"

# Concurrency cap (tune to your cluster)
MAX_CONCURRENCY=200
ARRAY_SPEC="0-$((COUNT-1))%${MAX_CONCURRENCY}"
echo "Submitting array: $ARRAY_SPEC"

# Submit the array workers; $SLURM_SUBMIT_DIR will be the project root
JID=$(sbatch --array="$ARRAY_SPEC" slurm/sweep_sim.sbatch | awk '{print $NF}')
echo "Array job id: $JID"

# Rebuild the global index only after all tasks succeed
sbatch --dependency=afterok:${JID} slurm/rebuild_index.sbatch
